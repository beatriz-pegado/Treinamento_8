@page
@{
    ViewData["Title"] = "Copa do Mundo";
    Layout = "/Pages/AreaRestrita/_Layout.cshtml";
}

@section head {
    <link href="~/css/Style.css" rel="stylesheet" />
}

<body>
    @* Gera o input hidden com o token necessário para o POST *@
    @Html.AntiForgeryToken()

    @await Component.InvokeAsync("Menu")

    <div id="tabs">
        <div class="container mt-5">
            <div class="d-flex flex-column gap-4">

                @* Cards de Aproveitamento e Gráfico *@
                <div class="d-flex gap-4">
                    <div class="card p-4 w-50">
                        <div class="d-flex gap-4">
                            <i class="fa-solid fa-coins fs-4 text-warning"></i>
                            <p class="h4 mb-5">Resumo de Aproveitamentos</p>
                        </div>
                        <div id="resultadoResumoAproveitamento" data-tipo-consulta="ResumoAproveitamento"></div>
                    </div>

                    <div class="card p-4 w-50">
                        <div class="d-flex gap-4">
                            <i class="fa-solid fa-chart-column fs-4 text-primary"></i>
                            <p class="h4 mb-5">Análise Financeira vs. Desempenho</p>
                        </div>
                        <div id="chartAproveitamento"></div>
                    </div>
                </div>

                @* Cards de Artilharia *@
                <div class="d-flex gap-4">
                    <div class="card p-4 w-50">
                        <div class="d-flex gap-4">
                            <i class="fa-solid fa-crown fs-4 text-warning"></i>
                            <p class="h4 mb-5">Artilharia dos times</p>
                        </div>
                        <div id="resultadoArtilharia" data-tipo-consulta="Artilharia">
                            <div class="d-flex justify-content-center spinner-container">
                                <div class="spinner-border text-primary" role="status">
                                    <span class="visually-hidden">Carregando...</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="card p-4 w-50">
                        <div class="d-flex gap-4">
                            <i class="fa-solid fa-chart-bar fs-4 text-danger"></i>
                            <p class="h4 mb-5">Ranking de Artilharia</p>
                        </div>
                        <div id="chartArtilharia"></div>
                    </div>
                </div>

                @* Cards de Jogos e Classificação *@
                <div class="d-flex gap-4">
                    <div class="card p-4 w-50">
                        <div class="d-flex gap-4">
                            <i class="fa-regular fa-futbol fs-4 text-success"></i>
                            <p class="h4 mb-5">Jogos Recentes</p>
                        </div>
                        <div id="resultadoJogosRecentes" data-tipo-consulta="JogosRecentes"></div>
                    </div>

                    <div class="card p-4 w-50">
                        <div class="d-flex gap-4">
                            <i class="fa-solid fa-ranking-star fs-4 text-primary"></i>
                            <p class="h4 mb-5">Classificação dos times</p>
                        </div>
                        <div id="resultadoClassificacao" data-tipo-consulta="Classificacao"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @section scripts {
        <script>
            function init() {
                // Seleciona todos os containers que possuem o atributo data-tipo-consulta
                makeSearch(document.getElementById('resultadoArtilharia'));
                makeSearch(document.getElementById('resultadoClassificacao'));
                makeSearch(document.getElementById('resultadoResumoAproveitamento'));
                makeSearch(document.getElementById('resultadoJogosRecentes'));
            }

            function makeSearch(obj) {
                if (!obj) return;

                var tipoConsulta = obj.getAttribute("data-tipo-consulta");
                var token = $('input[name="__RequestVerificationToken"]').val();

                $.ajax({
                    method: "POST",
                    url: "/AreaRestrita/AuxConsulta",
                    headers: {
                        "RequestVerificationToken": token
                    },
                    data: {
                        tipoConsulta: tipoConsulta
                    },
                    success: function (res) {
                        if (!res || res.length === 0) {
                            obj.innerHTML = "<div class='p-3 text-muted'>Nenhum registro encontrado</div>";
                            return;
                        }

                        // Popula a tabela
                        obj.innerHTML = populateTable(res);

                        // Renderiza os gráficos específicos
                        if (tipoConsulta === "Artilharia") {
                            renderizarApexArtilharia(res);
                        } else if (tipoConsulta === "ResumoAproveitamento") {
                            renderizarApexAproveitamento(res);
                        }
                    },
                    error: function (err) {
                        console.error("Erro ao carregar " + tipoConsulta, err);
                        obj.innerHTML = "<div class='text-danger p-3'>Erro ao carregar dados.</div>";
                    }
                });
            }

            function populateTable(json) {
                if (!json || json.length === 0) return "";
                var tablei = '<table class="table table-striped table-hover table-borderless table-scroll">';
                var thead = populateTableHeader(json);
                var tbody = populateTableBody(json);
                var tablef = '</table>';
                return tablei + thead + tbody + tablef;
            }

            function populateTableHeader(json) {
                var columns = Object.keys(json[0]);
                var headerCells = columns.map(r => "<th>" + r + "</th>");
                return "<thead><tr>" + headerCells.join('') + "</tr></thead>";
            }

            function populateTableBody(json) {
                var columns = Object.keys(json[0]);
                var results = json.map(r => {
                    var row = "<tr>";
                    columns.forEach(key => {
                        row += "<td data-column='" + key + "'>" + (r[key] ?? "") + "</td>";
                    });
                    row += "</tr>";
                    return row;
                });
                return "<tbody>" + results.join('') + "</tbody>";
            }

            function getChartTheme() {
                return document.documentElement.getAttribute('data-bs-theme') === 'dark' ? 'dark' : 'light';
            }

            function renderizarApexAproveitamento(dados) {
                var options = {
                    series: [{
                        name: 'Folha Salarial',
                        type: 'column',
                        data: dados.map(d => d.Folha)
                    }, {
                        name: 'Aproveitamento',
                        type: 'line',
                        data: dados.map(d => parseFloat(String(d.Aproveitamento).replace(',', '.')))
                    }],
                    chart: {
                        id: 'chartAproveitamento',
                        height: 235, type: 'line', 
                        toolbar: { show: false } },
                    theme: { mode: getChartTheme() },
                    stroke: { width: [0, 4] },
                    labels: dados.map(d => d.Nome),
                    yaxis: [
                        { title: { text: 'Folha Salarial (R$)' } },
                        { opposite: true, title: { text: 'Aproveitamento' }, min: 0, max: 1 }
                    ],
                    colors: ['#008FFB', '#00E396']
                };
                new ApexCharts(document.querySelector("#chartAproveitamento"), options).render();
            }

            function renderizarApexArtilharia(dados) {
                var options = {
                    series: [{
                        name: 'Gols',
                        data: dados.map(d => d.GolsMarcados)
                    }],
                    chart: { id: 'chartArtilharia', type: 'bar', height: 235, toolbar: { show: false } },
                    theme: { mode: getChartTheme() },
                    plotOptions: { bar: { horizontal: true, borderRadius: 4, distributed: true } },
                    xaxis: { categories: dados.map(d => d.Nome) },
                    legend: { show: false }
                };
                document.querySelector("#chartArtilharia").innerHTML = "";
                new ApexCharts(document.querySelector("#chartArtilharia"), options).render();
            }

            $(document).ready(function () {
                init();
            });
        </script>
    }
</body>
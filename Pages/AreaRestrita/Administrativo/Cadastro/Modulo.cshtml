@page

@{
    ViewData["Title"] = "Modulo";
}

@functions {

    private enum View
    {
        Index,
        New,
        Edit
    }

    public class Modulo
    {
        public string IdModulo { get; set; }
        public string IdSistema { get; set; }
        public string CodigoSistema { get; set; }
        public string CaptionSistema { get; set; }
        public string Codigo { get; set; }
        public string Caption { get; set; }
    }

    public class Sistema
    {
        public string IdSistema { get; set; }
        public string Caption { get; set; }
    }

    string acao = null;
    string idModulo = null;
    Modulo modulo = null;
    View view = View.Index;
    List<Modulo> modulos = null;
    List<Sistema> sistemas = null;
    List<Botao> botoes = null;

    private void AlimentaVariaveis()
    {
        if (HttpContext.Request.HasFormContentType)
        {
            acao = Util.ChecaNulo(Request.Form["acao"]);
            idModulo = Util.ChecaNulo(Request.Form["idModulo"]);
            if (!string.IsNullOrWhiteSpace(Request.Form["view"]))
            {
                view = (View)Enum.Parse(typeof(View), Request.Form["view"]);
            }
        }
        botoes = new BotaoDao().GetAll();
    }

    private void LimpaVariaveis()
    {
        acao = null;
        idModulo = null;
        modulo = null;
    }

    private void ConsultarModulos()
    {
        Dictionary<string, object> parametros = new Dictionary<string, object>();
        parametros.Add("@IdModulo", idModulo);
        parametros.Add("@TipoConsulta", 1);

        modulos = new Dao().ExecutarAcaoList<Modulo>("C", parametros);
    }
    private void ConsultarSistemas()
    {
        Dictionary<string, object> parametros = new Dictionary<string, object>();
        parametros.Add("@TipoConsulta", 2);

        sistemas = new Dao().ExecutarAcaoList<Sistema>("C", parametros);
    }

    private void Manutencao()
    {
        Dictionary<string, object> parametros = new Dictionary<string, object>();
        parametros.Add("@IdModulo", modulo.IdModulo);
        parametros.Add("@IdSistema", modulo.IdSistema);
        parametros.Add("@Codigo", modulo.Codigo);
        parametros.Add("@Caption", modulo.Caption);

        new Dao().ExecutarAcao(acao, parametros);
    }

    private void CarregarDados()
    {
        if (view == View.Edit && acao == "C" && modulos != null && modulos.Count() == 1)
        {
            modulo = modulos.FirstOrDefault();
        }
    }
}
@{
    AlimentaVariaveis();

    if (acao == "I" || acao == "A" || acao == "E")
    {
        Util.ExceptionHandler(() =>
        {
            if (HttpContext.Request.HasFormContentType)
            {
                modulo = new Modulo()
                {
                    IdModulo = Util.ChecaNulo(Request.Form["idModulo"]),
                    IdSistema = Util.ChecaNulo(Request.Form["idSistema"]),
                    Codigo = Util.ChecaNulo(Request.Form["codigo"]),
                    Caption = Util.ChecaNulo(Request.Form["caption"])
                };
            }
            Manutencao();
            view = View.Index;
            LimpaVariaveis();
            ModelState.AddModelError("alert-success", "Operação realizada com sucesso.");
        }, this.ModelState);
    }

    Util.ExceptionHandler(() =>
    {
        ConsultarModulos();
        ConsultarSistemas();
        CarregarDados();

    }, this.ModelState);

    if (modulo == null)
    {
        modulo = new Modulo();
    }
}
@section head {
    <link href="~/Scripts/Style.css" rel="stylesheet">
}

<body>
    <form name="form1" method="post">

        <input type="hidden" name="acao" id="acao" />
        <input type="hidden" name="idModulo" id="idModulo" value="@idModulo" />
        <input type="hidden" name="view" id="view" value="@((int)view)" />

        

        <div class="container mt-5 pt-5">
            <div class="d-flex justify-content-between mt-3 mb-5">
                <p class="h1">Módulo</p>

                <div class="d-flex align-items-center ms-auto gap-2">

                    <!--botao azul  class="btn btn-sm btn-primary"-->
                    @if (view == View.Index)
                    {
                        if (botoes.Any(x => x.Codigo == "I"))
                        {
                            <button class="btn btn-outline-primary" type="button" onclick="novo()">Novo</button>
                        }

                    }
                    @if (view == View.New)
                    {
                        @await Html.PartialAsync("Shared/Helpers/_BotaoHelper", new Treinamento8_0.Models.BotaoModel { Lista = botoes, Acao = "I" })
                    }


                    @if (view == View.Edit)
                    {
                        @await Html.PartialAsync("Shared/Helpers/_BotaoHelper", new Treinamento8_0.Models.BotaoModel { Lista = botoes, Acao = "A" })
                        @await Html.PartialAsync("Shared/Helpers/_BotaoHelper", new Treinamento8_0.Models.BotaoModel { Lista = botoes, Acao = "E" })
                    }

                    <button class="btn btn-outline-primary" type="submit" onclick="estadoInicial()">Limpar</button>
                </div>
            </div>

            <div class="position-absolute alert fade show" style="top: 10px; right: 100px;" role="alert">
                @await Html.PartialAsync("Shared/Helpers/_MakeAlert")
            </div>

            @if (view == View.New || view == View.Edit)
            {
                <div class="input-group mb-3">
                    <label class="input-group-text" for="idSistema">Sistema: </label> <br />
                    <select class="form-select  @Util.IsInvalid("idSistema", this.ModelState)" name="idSistema">
                        <option value="">Selecione um Sistema</option>

                        @foreach (Sistema item in sistemas)
                        {
                            <!option @(item.IdSistema == modulo.IdSistema ? "selected" : "")
                                    value="@item.IdSistema">
                                @item.Caption
                            </!option>
                        }
                    </select>
                    @await Html.PartialAsync("Shared/Helpers/_MakeFeedback", "idSistema")
                </div>

                <div class="input-group mb-3">
                    <label class="input-group-text is-invalid">Código do Módulo: </label>
                    <input class="form-control @Util.IsInvalid("codigo", this.ModelState)" type="text" name="codigo" id="codigo" value="@modulo.Codigo" />
                    @await Html.PartialAsync("Shared/Helpers/_MakeFeedback", "codigo")
                </div>

                <div class="input-group mb-3">
                    <label class="input-group-text is-invalid">Caption do Módulo: </label>
                    <input class="form-control @Util.IsInvalid("caption", this.ModelState)" type="text" name="caption" id="caption" value="@modulo.Caption" />
                    @await Html.PartialAsync("Shared/Helpers/_MakeFeedback", "caption")
                </div>
            }

            @if (view == View.Index)
            {
                <div class="table-wrapper table-responsive">
                    <table class="table table-striped table-hover table-borderless table-scroll">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Código do Sistema</th>
                                <th>Caption do Sistema</th>
                                <th>Código do Módulo</th>
                                <th>Caption do Módulo</th>
                                @if (botoes.Any(x => x.Codigo == "A" || x.Codigo == "E"))
                                {
                                    <th></th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (Modulo item in modulos)
                            {
                                <tr>
                                    <td>@item.IdModulo</td>
                                    <td>@item.CodigoSistema</td>
                                    <td>@item.CaptionSistema</td>
                                    <td>@item.Codigo</td>
                                    <td>@item.Caption</td>
                                    @if (botoes.Any(x => x.Codigo == "A" || x.Codigo == "E"))
                                    {
                                        <td><button class="btn btn-sm btn-primary js-setId" data-id="@item.IdModulo">Editar</button></td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </form>

    <script src="~/Scripts/Scripts.js"></script>

    <script>
        function setId(idModulo) {
            document.form1.view.value = "@((int)View.Edit)";
            document.form1.idModulo.value = idModulo;
            executarAcao('C');
        }

        function novo() {
            document.form1.view.value = "@((int)View.New)";
            executarAcao('');
        }

        function adicionaEventos() {
            Array.from(document.querySelectorAll('.js-setId')).forEach(function (item) {
                item.addEventListener("click", function () {
                    var id = this.getAttribute("data-id");
                    setId(id);
                });
            });
        }

        adicionaEventos();
    </script>

</body>



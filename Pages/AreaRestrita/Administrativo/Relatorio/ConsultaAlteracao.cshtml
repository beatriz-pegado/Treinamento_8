@page
@{
    ViewData["Title"] = "Alterações de Operadores";
}

<body>
    <form name="form1" method="post">
        <input type="hidden" name="acao" id="acao" />
        @Html.AntiForgeryToken()

        <div class="position-absolute alert fade show" style="top: 10px; right: 100px;" role="alert">
            @await Html.PartialAsync("Shared/Helpers/_MakeAlert")
        </div>

        <div class="container mt-5 pt-5">
            <div class="d-flex justify-content-between mt-3 mb-4">
                <p class="h2">Alterações de Operadores</p>
            </div>
            <div class="card mb-4 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title mb-3">Operador</h5>
                    <div class="row g-3 align-items-center">
                        <div class="col-md-4">
                            <div class="input-group">
                                <label for="cpf" class="input-group-text">CPF</label>
                                <input type="text" id="cpf" name="cpf" class="form-control" data-group="group1" data-column="Cpf" readonly />
                                @await Html.PartialAsync("Shared/Helpers/_MakeFeedback", "cpf")
                            </div>
                        </div>

                        <div class="col-md-2 d-flex align-items-center">
                            @await Html.PartialAsync("Shared/Helpers/_MakeModal", 
                                new Treinamento8_0.Models.Modal {   
                                    group = "group1", 
                                    label = "Operador", 
                                    tipoConsulta = "Operador", 
                                    title = "Consulta de Operadores" 
                                })
                        </div>

                        <div class="col-md-6">
                            <div class="input-group">
                                <label for="nomeOperador" class="input-group-text">Nome</label>
                                <input type="text" id="nomeOperador" name="nomeOperador" class="form-control" data-group="group1" data-column="Nome" readonly />
                                @await Html.PartialAsync("Shared/Helpers/_MakeFeedback", "nomeOperador")
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mb-4 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title mb-3">Página</h5>
                    <div class="row g-3 align-items-center">
                        <div class="col-md-4">
                            <div class="input-group">
                                <label for="pagina" class="input-group-text">Página</label>
                                <input type="text" id="pagina" name="pagina" class="form-control" data-group="group2" data-column="idPagina" readonly />
                                @await Html.PartialAsync("Shared/Helpers/_MakeFeedback", "pagina")
                            </div>
                        </div>

                        <div class="col-md-2 d-flex align-items-center">
                            @await Html.PartialAsync("Shared/Helpers/_MakeModal", 
                            new Treinamento8_0.Models.Modal { 
                                group = "group2", 
                                label = "Página", 
                                tipoConsulta = "Pagina", 
                                title = "Consulta de Páginas", 
                                consultaComposta="cpf"
                            })
                        </div>

                        <div class="col-md-6">
                            <div class="input-group">
                                <label for="nomePagina" class="input-group-text">Nome</label>
                                <input type="text" id="nomePagina" name="nomePagina" class="form-control" data-group="group2" data-column="Nome" readonly />
                                @await Html.PartialAsync("Shared/Helpers/_MakeFeedback", "nomePagina")
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mb-4 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title mb-3">Período</h5>
                    <div class="row g-3 align-items-center">
                        <div class="col-md-3">
                            <div class="input-group">
                                <label for="dataInicio" class="input-group-text">Data início</label>
                                <input type="date" id="dataInicio" name="dataInicio" class="form-control" />
                                @await Html.PartialAsync("Shared/Helpers/_MakeFeedback", "dataInicio")
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="input-group">
                                <label for="dataFim" class="input-group-text">até</label>
                                <input type="date" id="dataFim" name="dataFim" class="form-control" />
                                @await Html.PartialAsync("Shared/Helpers/_MakeFeedback", "dataFim")
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="search" data-group="group3" data-consulta-composta="pagina">
                <div class="d-flex gap-2 justify-content-center mt-4">
                    <input hidden type="text" id="idOperador" name="chave" value="" class="form-control" />
                    <button class="btn btn-outline-primary" type="button" name="pesquisar" id="pesquisar" onclick="makeSearchAlteracao(this)"> Pesquisar </button>
                    <button class="btn btn-outline-primary" type="submit" onclick="estadoInicial()">Limpar</button>
                    <button type="button" onclick="imprimirRelatorio()" class="btn btn-outline-primary"> Imprimir </button>
                </div>
            </div>

            <div id="resultadoAlteracoes" class="mt-5"></div>
        </div>
    </form>

    <script>

        var alteracoesJson = [];

        function openSearch(obj) {
            if (!obj) return;

            var group = findGroup(obj);

            if (!group) return;

            var search = document.querySelector(`[data-group="${group}"][class="search"]`);

            if (!search) return;

            var card = search.querySelector(".search-card");

            if (!card) return;

            card.classList.add("show");

            initSearch(search);
        }

        function closeSearch(obj) {
            if (!obj) return;

            var group = findGroup(obj);

            if (!group) return;

            var search = document.querySelector(`[data-group="${group}"][class="search"]`);

            if (!search) return;

            var card = search.querySelector(".search-card");

            if (!card) return;

            card.classList.remove("show");

            initSearch(search);
        }

        function initSearch(search) {
            var chave = search.querySelector('[name="chave"]');

            if (!chave) return;

            chave.value = "";

            var resultado = search.querySelector('.resultado');

            if (!resultado) return;

            resultado.innerHTML = "";
        }

        function makeSearch(obj) {
            if (!obj) return;

            var group = findGroup(obj);

            if (!group) return;

            var search = document.querySelector(`[data-group="${group}"][class="search"]`);

            if (!search) return;

            var chave = search.querySelector('[name="chave"]').value;
            var tipoConsulta = search.getAttribute("data-tipo-consulta");
            if (search.getAttribute("data-consulta-composta")) {
                var consultaComposta = document.getElementById(search.getAttribute("data-consulta-composta")).value;
            }
            var resultado = search.querySelector('.resultado');

            $.ajax({
                method: "POST",
                url: "/AreaRestrita/AuxConsulta",
                dataType: "json",
                headers: {
                    "RequestVerificationToken": $('input:hidden[name="__RequestVerificationToken"]').val()
                },
                data: {
                    chave: chave,
                    tipoConsulta: tipoConsulta,
                    consultaComposta: consultaComposta
                }
            }).done(function (res) {
                if (res.length == 0) {
                    resultado.innerHTML = "<div>Nenhum registro encontrado</div>";
                } else {
                    var table = populateTable(res);
                    resultado.innerHTML = table;
                }
            });
        }

        function populateTable(json) {
            var tableWrapperi = '<div class="table-wrapper table-responsive">';
            var tablei = '<table class="table table-striped table-hover table-borderless table-scroll">';
            var thead = populateTableHeader(json);
            var tbody = populateTableBody(json);
            var tablef = '</table>';
            var tableWrapperf = '</div>'

            return tableWrapperi + tablei + thead + tbody + tablef + tableWrapperf;
        }

        function populateTableHeader(json) {
            var columns = Object.keys(json[0]);
            var headerCells = columns.map(r => {
                return "<th>" + r + "</th>"
            });

            return "<thead><tr>" + headerCells.join('') + "</tr></thead>";
        }

        function populateTableBody(json) {
            var columns = Object.keys(json[0]);
            var results = json.map((r, index) => {
                var row = "<tr onclick='fecharSearch(this)'>";
                columns.forEach(function (key) {
                    row += "<td data-column=" + key + ">" + r[key] + "</td>";
                });
                row += "</tr>";
                return row;
            });

            return "<tbody>" + results.join('') + "</tbody>"
        }

        function makeSearchAlteracao(obj) {
            if (!obj) return;

            var group = findGroup(obj);
            if (!group) return;

            var search = document.querySelector(`[data-group="${group}"][class="search"]`);
            if (!search) return;

            var chave = document.getElementById('cpf');
            var nomePagina = document.getElementById('nomePagina').value;
            var tipoConsulta = "Alteracoes" + (nomePagina ? nomePagina : "");
            var dataInicio = document.getElementById('dataInicio');
            var dataFim = document.getElementById('dataFim');
            var consultaComposta = search.getAttribute("data-consulta-composta")
                ? document.getElementById(search.getAttribute("data-consulta-composta")).value
                : null;

            var resultado = document.getElementById('resultadoAlteracoes');

            // limpa mensagens anteriores
            resultado.innerHTML = "";

            $.ajax({
                method: "POST",
                url: "/AreaRestrita/AuxConsultaAlteracao",
                dataType: "json",
                headers: {
                    "RequestVerificationToken": $('input:hidden[name="__RequestVerificationToken"]').val()
                },
                data: {
                    chave: chave.value,
                    tipoConsulta: tipoConsulta,
                    consultaComposta: consultaComposta,
                    dataInicio: dataInicio.value,
                    dataFim: dataFim.value
                }
            })
                .done(function (res) {
                    if (!res.sucesso) {
                        resultado.innerHTML = `<div class="alert alert-danger">${res.mensagem || "Erro ao consultar dados."}</div>`;
                        return;
                    }

                    if (!res.dados || res.dados.length === 0) {
                        resultado.innerHTML = "<div>Nenhum registro encontrado</div>";
                    } else {
                        alteracoesJson = res.dados;
                        resultado.innerHTML = populateTableAlteracao(res.dados);
                    }
                })
                .fail(function () {
                    resultado.innerHTML = `<div class="alert alert-danger">Erro na comunicação com o servidor.</div>`;
                });
        }

        /* Formata tabela de alterações do operador */

        /* Formatação de caracteres especiais */
        function escapeHtml(value) {
            if (value == null) return "";
            return String(value)
                .replace(/&/g, "&amp;")
                .replace(/</g, "&lt;")
                .replace(/>/g, "&gt;")
                .replace(/"/g, "&quot;");
        }

        /* Colunas fixas para todas as tabelas */
        const COLUMNS = {
            data: "Data",
            ip: "ViaIp",
            tabela: "Tabela",
            operacao: "Operação",
            info: "Informacao",
            para: "Para",
            sessao: "idSessao"
        };

        function populateTableAlteracao(json) {
            if (!json || json.length === 0) return "<div>Nenhum registro encontrado</div>";

            return `<div class="table-wrapper table-responsive">
                    <table class="table table-hover table-bordered table-sm table-scroll">
                        ${populateHeaderAlteracao()}
                        ${populateBodyAlteracao(json)}
                    </table>
                </div>`;
        }

        function populateHeaderAlteracao() {
            return `<thead>
                            <tr>
                                <th>Data</th>
                                <th>IP</th>
                                <th>Tabela</th>
                                <th>Operação</th>
                                <th>Informação</th>
                                <th>Para</th>
                            </tr>
                        </thead>`;
        }

        function populateBodyAlteracao(json) {
            function makeGroupKey(r) {
                return [r[COLUMNS.data], r[COLUMNS.ip], r[COLUMNS.tabela], r[COLUMNS.operacao], r[COLUMNS.sessao]].join("|");
            }

            const grupos = [];
            const keyMap = new Map();

            json.forEach((r) => {
                const key = makeGroupKey(r);
                if (!keyMap.has(key)) {
                    const grupo = { key, meta: r, linhas: [] };
                    keyMap.set(key, grupo);
                    grupos.push(grupo);
                }
                keyMap.get(key).linhas.push(r);
            });

            let tbody = "<tbody>";

            grupos.forEach((grupo, index) => {
                const { meta, linhas } = grupo;

                if (index > 0) {
                    tbody += `<tr class="table-group-divider"><td colspan="6"></td></tr>`;
                }

                linhas.forEach((linha, i) => {
                    tbody += "<tr>";

                    if (i === 0) {
                        tbody += `<td>${escapeHtml(meta[COLUMNS.data])}</td>`
                            + `<td>${escapeHtml(meta[COLUMNS.ip])}</td>`
                            + `<td>${escapeHtml(meta[COLUMNS.tabela])}</td>`
                            + `<td><span class="badge ${tipoOperacao(meta[COLUMNS.operacao])}">${escapeHtml(meta[COLUMNS.operacao])}</span></td>`;
                    } else {
                        tbody += "<td></td><td></td><td></td><td></td>";
                    }

                    tbody += `<td>${escapeHtml(linha[COLUMNS.info])}</td>`
                        + `<td>${escapeHtml(linha[COLUMNS.para])}</td>`
                        + "</tr>";
                });
            });

            tbody += "</tbody>";
            return tbody;
        }

        function tipoOperacao(operacao) {
            if (operacao == "Inclusão") {
                return "bg-success";
            } else if (operacao == "Alteração") {
                return "bg-warning text-dark";
            } else if (operacao == "Remoção") {
                return "bg-danger";
            }
        }

        function fecharSearch(obj) {
            var group = findGroup(obj);

            if (!group) return;

            document.querySelectorAll('[data-group="' + group + '"]').forEach((item) => {
                if (item instanceof HTMLInputElement) {

                    var column = item.getAttribute("data-column");
                    var cell = obj.querySelector('[data-column="' + column + '"]');

                    if (cell) {
                        item.value = cell.innerText;
                    }
                }
            });

            closeSearch(obj);

        }

        function findGroup(obj) {
            if (obj.classList.contains("search")) {
                return obj.getAttribute("data-group");
            }
            return findGroup(obj.parentElement);
        }

        function imprimirRelatorio() {
            var nomePagina = document.getElementById('nomePagina').value;
            var tipoConsulta = "Alteracoes" + (nomePagina ? nomePagina : "");
            var dataInicio = document.getElementById("dataInicio").value;
            var dataFim = document.getElementById("dataFim").value;
            var cpf = document.getElementById("cpf").value;
            var nomeOperador = document.getElementById("nomeOperador").value;
            var dataAtual = new Date().toLocaleString('pt-BR', {
                dateStyle: 'short',
                timeStyle: 'short'
            });


            if (cpf == null || cpf == "") {
                alert("Selecione um operador!");
            } else {
                const url = `RelatorioAlteracao?dataInicio=${dataInicio}&dataFim=${dataFim}&cpf=${cpf}&tipoConsulta=${tipoConsulta}&nomeOperador=${nomeOperador}&dataAtual=${dataAtual}`;
                var frame = document.createElement("iframe");
                frame.style.display = "none";
                frame.src = url;

                document.body.appendChild(frame);

                frame.onload = function () {
                    frame.contentWindow.print();
                    frame.contentWindow.addEventListener("afterprint", function () {
                        document.body.removeChild(frame);
                    });
                }
            }

        }
    </script>

</body>



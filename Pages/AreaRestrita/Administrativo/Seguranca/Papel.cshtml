@page
@{
    ViewData["Title"] = "Papel";
}

@functions{

    private enum View
    {
        Index,
        New,
        Edit
    }

    public class Papel
    {
        public string IdPapel { get; set; }
        public string Nome { get; set; }
        public string acoes { get; set; }
    }

    public class AcaoPapel
    {
        public string IdAcaoPapel { get; set; }
        public string IdAcao { get; set; }
        public string NomeAcao { get; set; }
        public string NomeSistema { get; set; }
        public string NomeModulo { get; set; }
        public string NomePagina { get; set; }
    }

    string acao = null;
    string acoes = null;
    string idPapel = null;

    List<Papel> papeis = null;
    Papel papel = null;

    List<AcaoPapel> acoesPapel = null;
    List<Botao> botoes = null;

    View view = View.Index;

    private void AlimentaVariaveis()
    {
        if (HttpContext.Request.HasFormContentType)
        {
            acao = Util.ChecaNulo(Request.Form["acao"]);
            idPapel = Util.ChecaNulo(Request.Form["idPapel"]);
            acoes = Util.ChecaNulo(Request.Form["idAcao"]);

            if (!string.IsNullOrWhiteSpace(Request.Form["view"]))
            {
                view = (View)Enum.Parse(typeof(View), Request.Form["view"]);
            }
        }
        botoes = new BotaoDao().GetAll();
    }

    private void ConsultarPapeis()
    {
        Dictionary<string, object> parametros = new Dictionary<string, object>();
        parametros.Add("@TipoConsulta", 0);
        parametros.Add("@IdPapel", idPapel);

        papeis = new Dao().ExecutarProcedureList<Papel>("stp_ABP_Papel_Sel", parametros);
    }

    private void ConsultarAcoesPapel()
    {
        Dictionary<string, object> parametros = new Dictionary<string, object>();
        parametros.Add("@TipoConsulta", 1);
        parametros.Add("@IdPapel", idPapel);

        acoesPapel = new Dao().ExecutarProcedureList<AcaoPapel>("stp_ABP_Papel_Sel", parametros);
    }

    private void Manutencao()
    {
        Dictionary<string, object> parametros = new Dictionary<string, object>();
        parametros.Add("@IdPapel", papel.IdPapel);
        parametros.Add("@Nome", papel.Nome);
        parametros.Add("@Acoes", acoes);

        new Dao().ExecutarAcao(acao, parametros);
    }

    private void CarregarDados()
    {
        if (view == View.Edit && acao == "C" && papeis != null && papeis.Count() == 1)
        {
            papel = papeis.FirstOrDefault();
        }
    }

    private void LimpaVariaveis()
    {
        acao = null;
        papel = null;
        idPapel = null;
    }
}

@{
    AlimentaVariaveis();
    ConsultarPapeis();
    CarregarDados();

    if(view == View.Edit)
    {
        ConsultarAcoesPapel();
    }

    if (acao == "I" || acao == "A" || acao == "E")
    {
        Util.ExceptionHandler(() =>
        {
            papel = new Papel()
            {
                IdPapel = Util.ChecaNulo(Request.Form["idPapel"]),
                Nome = Util.ChecaNulo(Request.Form["nomePapel"]),
            };
            Manutencao();
            view = View.Index;
            LimpaVariaveis();
            ModelState.AddModelError("alert-success", "Operação realizada com sucesso.");
        }, this.ModelState);
    }

    if(papel == null)
    {
        papel = new Papel();
    }
}


<body>

    <form name="form1" method="post">

        <input type="hidden" name="acao" id="acao" />
        <input type="hidden" name="idPapel" id="idPapel" value="@idPapel" />
        <input type="hidden" name="view" id="view" value="@((int)view)" />

        @Html.AntiForgeryToken()

    <div class="container mt-5 pt-5">
        <div class="d-flex justify-content-between mt-3 mb-5">
            <p class="h1">Papel</p>

            <div class="d-flex align-items-center ms-auto gap-2">
                @if (view == View.New)
                {
                        @await Html.PartialAsync("Shared/Helpers/_BotaoHelper", new Treinamento8_0.Models.BotaoModel { Lista = botoes, Acao = "I" })
                }

                @if (view == View.Edit)
                {
                    @await Html.PartialAsync("Shared/Helpers/_BotaoHelper", new Treinamento8_0.Models.BotaoModel { Lista = botoes, Acao = "A" })
                    @await Html.PartialAsync("Shared/Helpers/_BotaoHelper", new Treinamento8_0.Models.BotaoModel { Lista = botoes, Acao = "E" })
                }

                @if (view == View.Index)
                {
                    if (botoes.Any(x => x.Codigo == "I"))
                    {
                        <button class="btn btn-outline-primary" type="button" onclick="novo()">Novo</button>
                    }

                }
                <button class="btn btn-outline-primary" type="submit" onclick="estadoInicial()">Limpar</button>
            </div>
        </div>

        <div class="position-absolute alert fade show" style="top: 10px; right: 100px;" role="alert">
                @await Html.PartialAsync("Shared/Helpers/_MakeAlert")
        </div>

        @if (view == View.Index)
        {
            <div class="card mt-2">
                <div class='p-2'>
                    <div class="d-flex gap-2 mt-2">
                        <div class="flex-grow-1">
                            <input type="text" name="pesquisa" id="pesquisa" class="form-control" placeholder="Buscar papel por id ou nome" />
                        </div>
                    </div>
                </div>
                <div class="resultado"></div>
            </div>

        }

        @if (view == View.New || view == View.Edit)
        {
            <div class="input-group mb-3">
                <label class="input-group-text is-invalid" for="nomePapel">Nome do Papel: </label>
                <input class="form-control @Util.IsInvalid("nomePapel", this.ModelState)" type="text" name="nomePapel" id="nomePapel" value="@papel.Nome" />
                    @await Html.PartialAsync("Shared/Helpers/_MakeFeedback", "nomePapel")
            </div>

            if (acoesPapel != null)
            {
                string idSistema = null;
                string idModulo = null;
                string idPagina = null;

                <div class="shadow-sm border rounded">
                    @foreach (AcaoPapel item in acoesPapel)
                    {
                        var sistemaId = item.NomeSistema.Replace(" ", "");
                        var moduloId = sistemaId + item.NomeModulo.Replace(" ", "");
                        var paginaId = moduloId + item.NomePagina.Replace(" ", "");

                        if (idSistema != item.NomeSistema && idSistema != null)
                        {
                            @Html.Raw("</div></div></div>")
                            idModulo = null;
                            idPagina = null;
                        }

                        if (idSistema != item.NomeSistema)
                        {
                            @Html.Raw($@"
                                </div>
                                <div class='card border-0 rounded-0'>
                                    <div class='card-header bg-light-subtle d-flex align-items-center'
                                         data-bs-toggle='collapse' data-bs-target='#sistema_{sistemaId}'
                                         style='cursor:pointer; height: 50px;'>
                                            <strong>{item.NomeSistema}</strong>
                                    </div>
                                    <div id='sistema_{sistemaId}' class='collapse'>
                            ")
                        }

                        if (idModulo != item.NomeModulo && idModulo != null)
                        {
                            @Html.Raw("</div></div></div>")
                            idPagina = null;
                        }

                        if (idModulo != item.NomeModulo)
                        {
                            @Html.Raw($@"
                                <div class='border-bottom'>
                                    <div class='bg-secondary bg-opacity-10 px-4 py-2 d-flex justify-content-between align-items-center'
                                         data-bs-toggle='collapse' data-bs-target='#modulo_{moduloId}'
                                         style='cursor:pointer'>
                                        <span class='text-secondary small fw-bold text-uppercase'>{item.NomeModulo}</span>
                                        <i class='bi bi-chevron-down small text-secondary'></i>
                                    </div>
                                    <div id='modulo_{moduloId}' class='collapse'>
                            ")
                        }


                        if (idPagina != item.NomePagina && idPagina != null)
                        {
                            @Html.Raw("</div>")
                        }

                        if (idPagina != item.NomePagina)
                        {
                            @Html.Raw($@"
                                <div class='px-5 py-2 border-bottom'
                                     data-bs-toggle='collapse' data-bs-target='#pagina_{paginaId}'
                                     style='cursor:pointer'>
                                    <span class='text-primary fw-semibold'><i class='bi bi-file-earmark-text me-1'></i> {item.NomePagina}</span>
                                </div>
                                <div id='pagina_{paginaId}' class='collapse px-5 py-2'>
                            ")
                        }

                        <div class="row align-items-center py-2 border-bottom">
                            <div class="col-9 text-muted small">
                                @item.NomeAcao
                            </div>
                            <div class="col-3 text-end">
                                <div class="form-check form-switch d-inline-block">
                                    <input class="form-check-input" type="checkbox" name="idAcao" value="@item.IdAcao" @(item.IdAcaoPapel != null ? "checked" : "")>
                                </div>
                            </div>
                        </div>

                        idSistema = item.NomeSistema;
                        idModulo = item.NomeModulo;
                        idPagina = item.NomePagina;
                    }

                    @Html.Raw("</div></div></div>")
                </div>
            }

            @*if(view == View.Edit)
            {
                <div class="table-wrapper table-responsive">
                    <table class="table table-striped table-hover table-borderless table-scroll">
                        <thead>
                            <tr>
                                <th>Sistema</th>
                                <th>Módulo</th>
                                <th>Página</th>
                                <th>Ação</th>
                                @if (botoes.Any(x => x.Codigo == "A" || x.Codigo == "E"))
                                {
                                    <th>Permitir Ação</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (AcaoPapel item in acoesPapel)
                            {
                                <tr>
                                    <td>@item.NomeSistema</td>
                                    <td>@item.NomeModulo</td>
                                    <td>@item.NomePagina</td>
                                    <td>@item.NomeAcao</td>
                                    @if (botoes.Any(x => x.Codigo == "A" || x.Codigo == "E"))
                                    {
                                        <td><input type="checkbox" name="idAcao" value="@item.IdAcao" @(item.IdAcaoPapel != null ? "checked" : "")></td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }*@
        }
    </div>
    </form>
@section scripts {
        <script>
            function setId(idPapel) {
                document.form1.view.value = "@((int)View.Edit)";
                document.form1.idPapel.value = idPapel;
                executarAcao('C');
            }

            function novo() {
                document.form1.view.value = "@((int)View.New)";
                executarAcao('C');
            }

            function adicionaEventos() {
                Array.from(document.querySelectorAll('.js-setId')).forEach(function (item) {
                    item.addEventListener("click", function () {
                        var id = this.getAttribute("data-id");
                        setId(id);
                    });
                });


                // Adiciona debounce na pesquisa de registros
                document.form1.pesquisa.addEventListener('keyup', debounce(() => {
                    consultarItens();
                }, 300));
            }

            function consultarItens() {
                var resultado = document.querySelector('.resultado');

                resultado.innerHTML = '';

                // Se foi feita alguma pesquisa
                let pesquisa = document.form1.pesquisa.value;

                // Envia dados para a AuxPaginacao para que seja feita a consulta
                $.ajax({
                    type: "POST",
                    url: "/AreaRestrita/AuxPapel",
                    headers: {
                        "RequestVerificationToken": $('input:hidden[name="__RequestVerificationToken"]').val()
                    },
                    data: {
                        pesquisa: pesquisa
                    },
                    success: function (res) {
                        resultado.innerHTML = res;
                        adicionaEventos();
                    },
                    error: function (xhr) {
                        body.innerHTML = xhr.responseText;
                    },
                    finally: function () {
                        body.remove(div);
                    }
                });
            }

            // Define tempo de delay ao pesquisar
            function debounce(callback, delay) {
                let timeout;
                return function () {
                    clearTimeout(timeout);
                    timeout = setTimeout(callback, delay);
                }
            }

            function init() {
                adicionaEventos();
                consultarItens();
            }

            init();
        </script>
}
</body>